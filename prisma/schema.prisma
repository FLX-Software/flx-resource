generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum EmployeeStatus {
  AVAILABLE
  ASSIGNED
  VACATION
  SICK
  UNAVAILABLE
}

enum VehicleStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  UNAVAILABLE
}

enum SiteStatus {
  PLANNED
  ACTIVE
  COMPLETED
  PAUSED
}

model Employee {
  id        String         @id @default(cuid())
  firstName String
  lastName  String
  role      String
  phone     String?
  email     String?
  status    EmployeeStatus @default(AVAILABLE)
  skills    String?
  photoUrl  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  assignments Assignment[]
}

model Vehicle {
  id           String        @id @default(cuid())
  name         String
  licensePlate String
  type         String
  capacity     String?
  photoUrl     String?
  status       VehicleStatus @default(AVAILABLE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  assignments  Assignment[]
}

model ConstructionSite {
  id          String     @id @default(cuid())
  name        String
  address     String
  client      String?
  startDate   DateTime
  endDate     DateTime?
  status      SiteStatus @default(PLANNED)
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  assignments Assignment[]
}

model Assignment {
  id           String   @id @default(cuid())
  date         DateTime
  startMinutes Int      @default(480)
  endMinutes   Int      @default(1020)
  notes        String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  siteId String
  site   ConstructionSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([siteId])
  @@index([employeeId])
  @@index([vehicleId])
}
